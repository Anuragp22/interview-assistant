# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Speech / LLM providers
DEEPGRAM_API_KEY=
ELEVEN_API_KEY=
# Groq powers the LLM (OpenAI-compatible endpoint). Get a key at
# https://console.groq.com/keys
GROQ_API_KEY=
# Optional override; defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile

# Firebase Admin — pick ONE of the following two options:
#
# (A) Base64-encoded service-account JSON, single secret.
#     Recommended for production deploys (Render/Fly/etc.).
# FIREBASE_SERVICE_ACCOUNT_JSON=
#
# (B) The same three discrete fields the Next.js side uses
#     (firebase/admin.ts). Convenient in dev when you share a single
#     repo-root .env.local across both processes — the agent picks
#     these up automatically.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Pipeline tuning (optional; defaults are sane)
INTERRUPT_MIN_PARTIAL_SECONDS=0.4
INTERRUPT_MIN_WORDS=2
