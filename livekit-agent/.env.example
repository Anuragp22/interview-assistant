# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Speech / LLM providers
DEEPGRAM_API_KEY=
ELEVEN_API_KEY=
# Groq powers the LLM (OpenAI-compatible endpoint). Get a key at
# https://console.groq.com/keys
GROQ_API_KEY=
# Optional override; defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile

# Firebase Admin (base64-encoded service-account JSON)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Pipeline tuning (optional; defaults are sane)
INTERRUPT_MIN_PARTIAL_SECONDS=0.4
INTERRUPT_MIN_WORDS=2
