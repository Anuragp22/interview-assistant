# Firebase Configuration (Client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Configuration (Admin)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Groq — used by both the LLM in /api/interviews/generate (question
# generation) and createFeedback (Zod-structured scoring). Same key the
# Python agent uses for the live conversation LLM.
GROQ_API_KEY=
# Optional override; defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile

# LiveKit (replaces VAPI)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Speech / TTS providers (used by the Python agent — read here too because
# the agent loads this same .env.local in dev)
DEEPGRAM_API_KEY=
ELEVEN_API_KEY=

# OpenTelemetry — optional. Leave OTEL_EXPORTER_OTLP_ENDPOINT unset to
# fall back to console exporter (spans dump to stdout). To ship traces
# to Honeycomb: get a free API key at honeycomb.io, set the two vars
# below. Other OTLP backends (Grafana Cloud Tempo, Jaeger, OpenTelemetry
# Collector) work the same way — point OTEL_EXPORTER_OTLP_ENDPOINT at
# their /v1/traces endpoint and drop the Honeycomb-specific headers.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/v1/traces
# HONEYCOMB_API_KEY=
# HONEYCOMB_DATASET=interview-assistant
#
# Optional offline capture: when OTEL_TRACES_FILE is set, the Python
# agent writes every span as a one-per-line JSON object to this file
# (alongside the primary backend). Feed it into `npm run latency-report`
# to get per-leg p50/p95/p99 with budget verdicts. See docs/observability.md.
# OTEL_TRACES_FILE=eval/sessions/local.spans.jsonl
